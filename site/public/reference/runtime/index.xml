    <item>
      <title>RuntimeContext.mapEnvironment</title>
      <link>http://localhost:3000/reference/runtime/m-runtimecontext-mapenvironment/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/runtime/m-runtimecontext-mapenvironment/</guid>
      <description>&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;&lt;span&gt;RuntimeContext.mapEnvironment&amp;#32;&lt;span&gt;mapper&amp;#32;context&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;p&gt;Maps the application environment half of a runtime context.&lt;/p&gt;&#xA;&lt;h2 id=&#34;parameters&#34;&gt;Parameters&lt;/h2&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;code&gt;mapper&lt;/code&gt;: &lt;code&gt;&lt;span&gt;&amp;lsquo;env -&amp;gt; &amp;rsquo;nextEnv&lt;/span&gt;&lt;/code&gt;&#xA;A function of type &lt;code&gt;&#39;env -&amp;gt; &#39;nextEnv&lt;/code&gt;.&lt;/li&gt;&#xA;&lt;li&gt;&lt;code&gt;context&lt;/code&gt;: &lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-runtimecontext-2.html&#34;&gt;RuntimeContext&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;runtime, &amp;rsquo;env&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&#xA;The source context.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h2 id=&#34;returns&#34;&gt;Returns&lt;/h2&gt;&#xA;&lt;p&gt;A new context with the mapped environment.&lt;/p&gt;</description>
    </item>
    <item>
