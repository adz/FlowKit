    <item>
      <title>Ref.get</title>
      <link>http://localhost:3000/reference/ref/m-ref-get/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/ref/m-ref-get/</guid>
      <description>&lt;p&gt;Reads the current value of the reference.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;&lt;span&gt;Ref.get&amp;#32;&lt;span&gt;reference&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;parameters&#34;&gt;Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;reference&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-ref-1.html&#34;&gt;Ref&lt;/a&gt;&amp;lt;&amp;lsquo;T&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The &lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-ref-1.html&#34;&gt;Ref&lt;/a&gt; to read from.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;returns&#34;&gt;Returns&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-flow-3.html&#34;&gt;Flow&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;env, &amp;rsquo;none, &amp;lsquo;T&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;A flow that returns the current value.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;examples&#34;&gt;Examples&lt;/h2&gt;&#xA;&lt;pre class=&#34;fssnip highlighted&#34;&gt;&lt;code lang=&#34;fsharp&#34;&gt; &lt;span class=&#34;id&#34;&gt;Ref&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;get&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;myRef&lt;/span&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;</description>
    </item>
    <item>
      <title>Ref.make</title>
      <link>http://localhost:3000/reference/ref/m-ref-make/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/ref/m-ref-make/</guid>
      <description>&lt;p&gt;Creates a new &lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-ref-1.html&#34;&gt;Ref&lt;/a&gt; with the initial value.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;&lt;span&gt;Ref.make&amp;#32;&lt;span&gt;value&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;parameters&#34;&gt;Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;value&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&amp;lsquo;T&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The initial value of the reference.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;returns&#34;&gt;Returns&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-flow-3.html&#34;&gt;Flow&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;env, &amp;rsquo;none, &lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-ref-1.html&#34;&gt;Ref&lt;/a&gt;&amp;lt;&amp;lsquo;T&amp;gt;&lt;/span&gt;&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;A flow that creates and returns the reference.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;examples&#34;&gt;Examples&lt;/h2&gt;&#xA;&lt;pre class=&#34;fssnip highlighted&#34;&gt;&lt;code lang=&#34;fsharp&#34;&gt; &lt;span class=&#34;id&#34;&gt;Flow&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;run&lt;/span&gt; &lt;span class=&#34;pn&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;)&lt;/span&gt; &lt;span class=&#34;pn&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;Ref&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;make&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;10&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;)&lt;/span&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;</description>
    </item>
    <item>
      <title>Ref.modify</title>
      <link>http://localhost:3000/reference/ref/m-ref-modify/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/ref/m-ref-modify/</guid>
      <description>&lt;p&gt;Updates the value of the reference using the supplied function and returns a derived value.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;&lt;span&gt;Ref.modify&amp;#32;&lt;span&gt;f&amp;#32;reference&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;parameters&#34;&gt;Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;f&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&amp;lsquo;T -&amp;gt; &lt;span&gt;&amp;lsquo;T * &amp;lsquo;v&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The update function of type &lt;code&gt;&#39;T -&amp;gt; &#39;T * &#39;v&lt;/code&gt;.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;reference&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-ref-1.html&#34;&gt;Ref&lt;/a&gt;&amp;lt;&amp;lsquo;T&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The &lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-ref-1.html&#34;&gt;Ref&lt;/a&gt; to update.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;returns&#34;&gt;Returns&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-flow-3.html&#34;&gt;Flow&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;env, &amp;rsquo;none, &amp;lsquo;v&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;A flow that updates the value and returns the second part of the tuple returned by &lt;span class=&#34;fsdocs-param-name&#34;&gt;f&lt;/span&gt;.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;examples&#34;&gt;Examples&lt;/h2&gt;&#xA;&lt;pre class=&#34;fssnip highlighted&#34;&gt;&lt;code lang=&#34;fsharp&#34;&gt; &lt;span class=&#34;id&#34;&gt;Ref&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;modify&lt;/span&gt; &lt;span class=&#34;pn&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;k&#34;&gt;fun&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;x&lt;/span&gt; &lt;span class=&#34;k&#34;&gt;-&amp;gt;&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;x&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;+&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;,&lt;/span&gt; &lt;span class=&#34;s&#34;&gt;&amp;quot;increased&amp;quot;&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;)&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;myRef&lt;/span&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;</description>
    </item>
    <item>
      <title>Ref</title>
      <link>http://localhost:3000/reference/ref/t-ref-1/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/ref/t-ref-1/</guid>
      <description>&lt;p&gt;Represents a handle to a mutable reference that can be updated atomically.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;type Ref&lt;&#39;T&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;type-parameters&#34;&gt;Type Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;T&lt;/code&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;examples&#34;&gt;Examples&lt;/h2&gt;&#xA;&lt;pre class=&#34;fssnip highlighted&#34;&gt;&lt;code lang=&#34;fsharp&#34;&gt; &lt;span class=&#34;id&#34;&gt;flow&lt;/span&gt; &lt;span class=&#34;pn&#34;&gt;{&lt;/span&gt;&#xA;     &lt;span class=&#34;k&#34;&gt;let!&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;r&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;Ref&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;make&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;0&lt;/span&gt;&#xA;     &lt;span class=&#34;k&#34;&gt;do!&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;Ref&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;set&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;1&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;r&lt;/span&gt;&#xA;     &lt;span class=&#34;k&#34;&gt;let!&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;v&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;Ref&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;get&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;r&lt;/span&gt;&#xA;     &lt;span class=&#34;k&#34;&gt;return&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;v&lt;/span&gt;&#xA; &lt;span class=&#34;pn&#34;&gt;}&lt;/span&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;</description>
    </item>
    <item>
      <title>Ref.set</title>
      <link>http://localhost:3000/reference/ref/m-ref-set/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/ref/m-ref-set/</guid>
      <description>&lt;p&gt;Sets the value of the reference to the specified value.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;&lt;span&gt;Ref.set&amp;#32;&lt;span&gt;value&amp;#32;reference&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;parameters&#34;&gt;Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;value&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&amp;lsquo;T&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The new value to set.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;reference&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-ref-1.html&#34;&gt;Ref&lt;/a&gt;&amp;lt;&amp;lsquo;T&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The &lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-ref-1.html&#34;&gt;Ref&lt;/a&gt; to update.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;returns&#34;&gt;Returns&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-flow-3.html&#34;&gt;Flow&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;env, &amp;rsquo;none, unit&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;A flow that sets the value and returns unit.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;examples&#34;&gt;Examples&lt;/h2&gt;&#xA;&lt;pre class=&#34;fssnip highlighted&#34;&gt;&lt;code lang=&#34;fsharp&#34;&gt; &lt;span class=&#34;id&#34;&gt;Ref&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;set&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;20&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;myRef&lt;/span&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;</description>
    </item>
    <item>
      <title>Ref.update</title>
      <link>http://localhost:3000/reference/ref/m-ref-update/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/ref/m-ref-update/</guid>
      <description>&lt;p&gt;Updates the value of the reference using the supplied function.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;&lt;span&gt;Ref.update&amp;#32;&lt;span&gt;f&amp;#32;reference&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;parameters&#34;&gt;Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;f&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&amp;lsquo;T -&amp;gt; &amp;lsquo;T&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The update function of type &lt;code&gt;&#39;T -&amp;gt; &#39;T&lt;/code&gt;.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;reference&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-ref-1.html&#34;&gt;Ref&lt;/a&gt;&amp;lt;&amp;lsquo;T&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The &lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-ref-1.html&#34;&gt;Ref&lt;/a&gt; to update.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;returns&#34;&gt;Returns&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-flow-3.html&#34;&gt;Flow&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;env, &amp;rsquo;none, unit&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;A flow that updates the value and returns unit.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;examples&#34;&gt;Examples&lt;/h2&gt;&#xA;&lt;pre class=&#34;fssnip highlighted&#34;&gt;&lt;code lang=&#34;fsharp&#34;&gt; &lt;span class=&#34;id&#34;&gt;Ref&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;update&lt;/span&gt; &lt;span class=&#34;pn&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;k&#34;&gt;fun&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;x&lt;/span&gt; &lt;span class=&#34;k&#34;&gt;-&amp;gt;&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;x&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;+&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;)&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;myRef&lt;/span&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;</description>
    </item>
  </channel>
