    <item>
      <title>Schedule</title>
      <link>http://localhost:3000/reference/schedule/t-schedule/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/schedule/t-schedule/</guid>
      <description>&lt;p&gt;Represents a stateful schedule that can decide whether to continue and how long to delay.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;type Schedule&lt;&#39;env, &#39;input, &#39;output&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;type-parameters&#34;&gt;Type Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;env&lt;/code&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;input&lt;/code&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;output&lt;/code&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;</description>
    </item>
    <item>
      <title>Schedule.recurs</title>
      <link>http://localhost:3000/reference/schedule/m-schedule-recurs/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/schedule/m-schedule-recurs/</guid>
      <description>&lt;p&gt;Creates a schedule that recurs a fixed number of times.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;&lt;span&gt;Schedule.recurs&amp;#32;&lt;span&gt;n&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;parameters&#34;&gt;Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;n&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;int&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The maximum number of times to recur.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;returns&#34;&gt;Returns&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-schedule-3.html&#34;&gt;Schedule&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;env, &amp;lsquo;input, int&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;A schedule that recurs up to &lt;span class=&#34;fsdocs-param-name&#34;&gt;n&lt;/span&gt; times, emitting the current attempt count (0 to n-1).&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;examples&#34;&gt;Examples&lt;/h2&gt;&#xA;&lt;pre class=&#34;fssnip highlighted&#34;&gt;&lt;code lang=&#34;fsharp&#34;&gt; &lt;span class=&#34;k&#34;&gt;let&lt;/span&gt; &lt;span data-fsdocs-tip=&#34;fs1&#34; data-fsdocs-tip-unique=&#34;1&#34; class=&#34;id&#34;&gt;schedule&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;Schedule&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;recurs&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;3&lt;/span&gt;&#xA; &lt;span class=&#34;c&#34;&gt;// Will run for attempts 0, 1, 2 and then stop.&lt;/span&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&lt;div popover class=&#34;fsdocs-tip&#34; id=&#34;fs1&#34;&gt;val schedule: obj&lt;/div&gt;</description>
    </item>
    <item>
      <title>Schedule.spaced</title>
      <link>http://localhost:3000/reference/schedule/m-schedule-spaced/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/schedule/m-schedule-spaced/</guid>
      <description>&lt;p&gt;Creates a schedule that recurs with a fixed delay between attempts.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;&lt;span&gt;Schedule.spaced&amp;#32;&lt;span&gt;delay&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;parameters&#34;&gt;Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;delay&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;a href=&#34;https://learn.microsoft.com/dotnet/api/system.timespan&#34;&gt;TimeSpan&lt;/a&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The fixed time span to wait between each attempt.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;returns&#34;&gt;Returns&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-schedule-3.html&#34;&gt;Schedule&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;env, &amp;lsquo;input, int&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;A schedule that recurs indefinitely with the specified fixed delay, emitting the current attempt count.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;examples&#34;&gt;Examples&lt;/h2&gt;&#xA;&lt;pre class=&#34;fssnip highlighted&#34;&gt;&lt;code lang=&#34;fsharp&#34;&gt; &lt;span class=&#34;k&#34;&gt;let&lt;/span&gt; &lt;span data-fsdocs-tip=&#34;fs1&#34; data-fsdocs-tip-unique=&#34;1&#34; class=&#34;id&#34;&gt;schedule&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;Schedule&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;spaced&lt;/span&gt; &lt;span class=&#34;pn&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;TimeSpan&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;FromSeconds&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;1.0&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;)&lt;/span&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&lt;div popover class=&#34;fsdocs-tip&#34; id=&#34;fs1&#34;&gt;val schedule: obj&lt;/div&gt;</description>
    </item>
    <item>
      <title>Schedule.exponential</title>
      <link>http://localhost:3000/reference/schedule/m-schedule-exponential/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/schedule/m-schedule-exponential/</guid>
      <description>&lt;p&gt;Creates a schedule that recurs with exponential backoff.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;&lt;span&gt;Schedule.exponential&amp;#32;&lt;span&gt;baseDelay&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;parameters&#34;&gt;Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;baseDelay&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;a href=&#34;https://learn.microsoft.com/dotnet/api/system.timespan&#34;&gt;TimeSpan&lt;/a&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;The initial delay for the first retry.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;returns&#34;&gt;Returns&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-schedule-3.html&#34;&gt;Schedule&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;env, &amp;lsquo;input, &lt;a href=&#34;https://learn.microsoft.com/dotnet/api/system.timespan&#34;&gt;TimeSpan&lt;/a&gt;&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;A schedule that recurs indefinitely, doubling the delay each time (baseDelay * 2^attempt).&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;examples&#34;&gt;Examples&lt;/h2&gt;&#xA;&lt;pre class=&#34;fssnip highlighted&#34;&gt;&lt;code lang=&#34;fsharp&#34;&gt; &lt;span class=&#34;k&#34;&gt;let&lt;/span&gt; &lt;span data-fsdocs-tip=&#34;fs1&#34; data-fsdocs-tip-unique=&#34;1&#34; class=&#34;id&#34;&gt;schedule&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;Schedule&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;exponential&lt;/span&gt; &lt;span class=&#34;pn&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;TimeSpan&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;FromMilliseconds&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;100.0&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;)&lt;/span&gt;&#xA; &lt;span class=&#34;c&#34;&gt;// Delays: 100ms, 200ms, 400ms, 800ms...&lt;/span&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&lt;div popover class=&#34;fsdocs-tip&#34; id=&#34;fs1&#34;&gt;val schedule: obj&lt;/div&gt;</description>
    </item>
    <item>
      <title>Schedule.jittered</title>
      <link>http://localhost:3000/reference/schedule/m-schedule-jittered/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/schedule/m-schedule-jittered/</guid>
      <description>&lt;p&gt;Adds random jitter to a schedule&#39;s delay.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;&lt;span&gt;Schedule.jittered&amp;#32;&lt;span&gt;arg1&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;parameters&#34;&gt;Parameters&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Name&lt;/th&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;arg0&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-schedule-3.html&#34;&gt;Schedule&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;env, &amp;lsquo;input, &amp;lsquo;output&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;returns&#34;&gt;Returns&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Type&lt;/th&gt;&#xA;          &lt;th&gt;Description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;&lt;span&gt;&lt;a href=&#34;https://adz.github.io/FsFlow/reference/FsFlow/fsflow-schedule-3.html&#34;&gt;Schedule&lt;/a&gt;&amp;lt;&lt;span&gt;&amp;lsquo;env, &amp;lsquo;input, &amp;lsquo;output&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;A new schedule where each delay is multiplied by a random factor between 0.5 and 1.5.&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;examples&#34;&gt;Examples&lt;/h2&gt;&#xA;&lt;pre class=&#34;fssnip highlighted&#34;&gt;&lt;code lang=&#34;fsharp&#34;&gt; &lt;span class=&#34;k&#34;&gt;let&lt;/span&gt; &lt;span data-fsdocs-tip=&#34;fs1&#34; data-fsdocs-tip-unique=&#34;1&#34; class=&#34;id&#34;&gt;schedule&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;Schedule&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;spaced&lt;/span&gt; &lt;span class=&#34;pn&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;TimeSpan&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;FromSeconds&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;1.0&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;)&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;|&amp;gt;&lt;/span&gt; &lt;span class=&#34;id&#34;&gt;Schedule&lt;/span&gt;&lt;span class=&#34;pn&#34;&gt;.&lt;/span&gt;&lt;span class=&#34;id&#34;&gt;jittered&lt;/span&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&lt;div popover class=&#34;fsdocs-tip&#34; id=&#34;fs1&#34;&gt;val schedule: obj&lt;/div&gt;</description>
    </item>
  </channel>
